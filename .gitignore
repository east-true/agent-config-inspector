# If you prefer the allow list template instead of the deny list, see:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore

# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov
*.sarif

# Dependency directories (uncomment to exclude vendored dependencies)
# vendor/

# Go workspace files
go.work
go.work.sum

# Environment files and local secrets
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx

# Build and release output
/agent-config-inspector
/bin/
/dist/

# Editor/IDE settings should normally be ignored globally.
# .idea/
# .vscode/

# This repository snapshot is intentionally version-controlled.
!agent-config-inspector.lock.json
