{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/east-true/agent-config-inspector/schemas/snapshot.schema.json",
  "title": "Agent Config Inspector repository snapshot",
  "type": "object",
  "required": ["schema_version", "tool", "adapter_registry", "request", "entries", "lock_digest"],
  "properties": {
    "schema_version": { "const": 1 },
    "tool": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": { "const": "agent-config-inspector" },
        "version": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "adapter_registry": { "type": "string", "minLength": 1 },
    "request": {
      "type": "object",
      "required": ["targets", "providers"],
      "properties": {
        "targets": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "not": { "pattern": "^(?:/|[A-Za-z]:|\\.\\.?/|.*[\\r\\n\\u0000])" }
          }
        },
        "providers": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["anthropic-claude-code/cli", "openai-codex/cli"] }
        }
      },
      "additionalProperties": false
    },
    "entries": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/entry" } },
    "lock_digest": { "$ref": "#/$defs/digest" }
  },
  "additionalProperties": false,
  "$defs": {
    "digest": {
      "type": "object",
      "required": ["algorithm", "value"],
      "properties": {
        "algorithm": { "const": "sha256" },
        "value": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      },
      "additionalProperties": false
    },
    "provider": {
      "type": "object",
      "required": ["id", "adapter_id", "version_requirement", "support", "depth"],
      "properties": {
        "id": { "enum": ["anthropic-claude-code/cli", "openai-codex/cli"] },
        "adapter_id": { "type": "string", "minLength": 1 },
        "version_requirement": { "type": "string", "minLength": 1 },
        "support": { "type": "string", "minLength": 1 },
        "depth": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "scope": {
      "type": "object",
      "required": ["type", "status", "reason"],
      "properties": {
        "type": { "type": "string" },
        "base": { "type": "string" },
        "patterns": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string" },
        "reason": { "type": "string" }
      },
      "additionalProperties": false
    },
    "source": {
      "type": "object",
      "required": ["id", "logical_path", "kind", "scope"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "logical_path": {
          "type": "string",
          "minLength": 1,
          "not": { "pattern": "^(?:/|[A-Za-z]:[\\\\/]|\\.\\.?/|.*[\\r\\n\\u0000])" }
        },
        "kind": { "type": "string", "minLength": 1 },
        "raw_digest": { "$ref": "#/$defs/digest" },
        "normalized_digest": { "$ref": "#/$defs/digest" },
        "scope": { "$ref": "#/$defs/scope" },
        "order": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "entry": {
      "type": "object",
      "required": ["provider", "target", "state", "prediction", "included_sources", "excluded_sources", "effective_repository_digest"],
      "properties": {
        "provider": { "$ref": "#/$defs/provider" },
        "target": { "type": "string", "minLength": 1 },
        "state": { "enum": ["complete", "partial", "unknown"] },
        "prediction": { "enum": ["predicted-effective", "predicted-empty"] },
        "included_sources": { "type": "array", "items": { "$ref": "#/$defs/source" } },
        "excluded_sources": { "type": "array", "items": { "$ref": "#/$defs/source" } },
        "effective_repository_digest": { "$ref": "#/$defs/digest" }
      },
      "additionalProperties": false
    }
  }
}
